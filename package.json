{
  "name": "contabilidade",
  "version": "1.0.1",
  "private": true,
  "main": "electron.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "electron:dev": "electron .",
    "dist": "npm run build && electron-builder",
    "build:electron": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.contabilidade.app",
    "productName": "Contabilidade",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "start.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "db/postgres",
        "to": "postgres",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.4",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "react-toastify": "^11.0.5",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.5.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
